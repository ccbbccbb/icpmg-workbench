{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/app/**/{page,layout,template,loading,error,not-found,route}.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/components/ui/**"],
  "ignoreDependencies": ["tailwindcss", "sonner", "framer-motion"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "rules": {
    "files": "error",
    "dependencies": "error",
    "devDependencies": "error",
    "unlisted": "error",
    "exports": "warn",
    "types": "warn",
    "duplicates": "error"
  }
}
